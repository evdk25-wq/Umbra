#!/bin/bash

# Umbra - By JLVDK95

readonly REQUIRED_COMMANDS=("exiftool" "steghide" "magick" "openssl")

# Association des commandes avec leurs paquets Debian correspondants
get_package_name() {
    local cmd="$1"
    case "$cmd" in
        "magick") echo "imagemagick" ;;
        *) echo "$cmd" ;;
    esac
}

check_and_install_dependencies() {
    local missing_pkgs=()

    for cmd in "${REQUIRED_COMMANDS[@]}"; do
        if ! command -v "$cmd" &> /dev/null; then
            local pkg
            pkg=$(get_package_name "$cmd")
            missing_pkgs+=("$pkg")
        fi
    done

    if [[ ${#missing_pkgs[@]} -gt 0 ]]; then
        echo "Certains outils requis sont manquants : ${missing_pkgs[*]}"
        read -r -p "Voulez-vous les installer maintenant ? (y/N) : " response
        if [[ "$response" =~ ^[Yy]$ ]]; then
            echo "Mise à jour des dépôts et installation des paquets..."
            sudo apt update && sudo apt install -y "${missing_pkgs[@]}"
            
            # Vérification après tentative d'installation
            for cmd in "${REQUIRED_COMMANDS[@]}"; do
                if ! command -v "$cmd" &> /dev/null; then
                    echo "Erreur : L'installation de $cmd a échoué." >&2
                    exit 1
                fi
            done
            echo "Tous les outils ont été installés avec succès !"
        else
            echo "Erreur : Impossible de continuer sans les outils requis." >&2
            exit 1
        fi
    fi
}

validate_file_exists() {
    local file="$1"
    if [[ ! -f "$file" ]]; then
        echo "Erreur : Le fichier '$file' n'existe pas." >&2
        return 1
    fi
    return 0
}

display_metadata() {
    read -r -p "Entrez le chemin du fichier : " filepath
    validate_file_exists "$filepath" || return
    exiftool "$filepath"
}

embed_hidden_data() {
    read -r -p "Entrez l'image conteneur : " image
    validate_file_exists "$image" || return
    
    read -r -p "Entrez le fichier à cacher : " data
    validate_file_exists "$data" || return
    
    read -r -s -p "Entrez la clé secrète : " passphrase
    echo
    
    steghide embed -cf "$image" -ef "$data" -p "$passphrase"
    echo "Intégration réussie."
}

extract_hidden_data() {
    read -r -p "Entrez l'image conteneur : " image
    validate_file_exists "$image" || return
    
    read -r -s -p "Entrez la clé secrète : " passphrase
    echo
    
    steghide extract -sf "$image" -p "$passphrase"
}

convert_image() {
    read -r -p "Entrez le fichier JPEG à convertir : " jpeg
    validate_file_exists "$jpeg" || return
    
    read -r -p "Entrez le nom du fichier PNG de sortie : " png
    magick "$jpeg" "$png"
    echo "Conversion terminée : $png"
}

encrypt_file() {
    read -r -p "Entrez le fichier à chiffrer : " file
    validate_file_exists "$file" || return
    
    read -r -p "Entrez le nom du fichier chiffré de sortie : " output
    openssl enc -aes-256-cbc -salt -pbkdf2 -in "$file" -out "$output"
    echo "Fichier chiffré avec succès : $output"
}

decrypt_file() {
    read -r -p "Entrez le fichier chiffré : " file
    validate_file_exists "$file" || return
    
    read -r -p "Entrez le nom du fichier déchiffré de sortie : " output
    openssl enc -aes-256-cbc -d -pbkdf2 -in "$file" -out "$output"
    echo "Fichier déchiffré avec succès : $output"
}

display_menu() {
    cat << "EOF"
**************************
* Umbra          *
**************************
Welcome to Umbra - Steganography & Privacy Tool

1. Display metadata (ExifTool)
2. Embed hidden data (Steghide)
3. Extract hidden data (Steghide)
4. Convert an image (ImageMagick)
5. Encrypt a file (OpenSSL)
6. Decrypt a file (OpenSSL)
7. Exit
EOF
}

main() {
    check_and_install_dependencies
    display_menu

    while true; do
        read -r -p "Choisissez une option (1-7) : " option

        case $option in
            1) display_metadata ;;
            2) embed_hidden_data ;;
            3) extract_hidden_data ;;
            4) convert_image ;;
            5) encrypt_file ;;
            6) decrypt_file ;;
            7)
                echo "Au revoir !"
                break
                ;;
            *)
                echo "Option invalide. Veuillez réessayer." >&2
                ;;
        esac
    done
}

main "$@"

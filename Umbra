#!/bin/bash

# Umbra - By JLVDK95

readonly REQUIRED_COMMANDS=("exiftool" "steghide" "magick" "openssl")

get_package_name() {
    local cmd="$1"
    case "$cmd" in
        "magick") echo "imagemagick" ;;
        *) echo "$cmd" ;;
    esac
}

check_and_install_dependencies() {
    local missing_pkgs=()

    for cmd in "${REQUIRED_COMMANDS[@]}"; do
        if ! command -v "$cmd" &> /dev/null; then
            local pkg
            pkg=$(get_package_name "$cmd")
            missing_pkgs+=("$pkg")
        fi
    done

    if [[ ${#missing_pkgs[@]} -gt 0 ]]; then
        echo "Required tools are missing: ${missing_pkgs[*]}"
        read -r -p "Do you want to install them now? (y/N): " response
        if [[ "$response" =~ ^[Yy]$ ]]; then
            echo "Updating repositories and installing packages..."
            sudo apt update && sudo apt install -y "${missing_pkgs[@]}"
            
            for cmd in "${REQUIRED_COMMANDS[@]}"; do
                if ! command -v "$cmd" &> /dev/null; then
                    echo "Error: Installation of $cmd failed." >&2
                    exit 1
                fi
            done
            echo "All tools installed successfully!"
        else
            echo "Error: Cannot continue without required tools." >&2
            exit 1
        fi
    fi
}

validate_file_exists() {
    local file="$1"
    if [[ ! -f "$file" ]]; then
        echo "Error: File '$file' does not exist." >&2
        return 1
    fi
    return 0
}

display_metadata() {
    read -r -p "Enter file path: " filepath
    validate_file_exists "$filepath" || return
    exiftool "$filepath"
}

embed_hidden_data() {
    read -r -p "Enter cover image file: " image
    validate_file_exists "$image" || return
    
    read -r -p "Enter file to hide: " data
    validate_file_exists "$data" || return
    
    read -r -s -p "Enter secret passphrase: " passphrase
    echo
    
    steghide embed -cf "$image" -ef "$data" -p "$passphrase"
    echo "Data successfully embedded!"
}

extract_hidden_data() {
    read -r -p "Enter stego image file: " image
    validate_file_exists "$image" || return
    
    read -r -s -p "Enter secret passphrase: " passphrase
    echo
    
    steghide extract -sf "$image" -p "$passphrase"
}

convert_image() {
    read -r -p "Enter JPEG file to convert: " jpeg
    validate_file_exists "$jpeg" || return
    
    read -r -p "Enter output PNG file name: " png
    magick "$jpeg" "$png"
    echo "Conversion completed: $png"
}

encrypt_file() {
    read -r -p "Enter file to encrypt: " file
    validate_file_exists "$file" || return
    
    read -r -p "Enter output encrypted file name: " output
    openssl enc -aes-256-cbc -salt -pbkdf2 -in "$file" -out "$output"
    echo "File successfully encrypted: $output"
}

decrypt_file() {
    read -r -p "Enter encrypted file: " file
    validate_file_exists "$file" || return
    
    read -r -p "Enter output decrypted file name: " output
    openssl enc -aes-256-cbc -d -pbkdf2 -in "$file" -out "$output"
    echo "File successfully decrypted: $output"
}

display_menu() {
    cat << "EOF"
**************************
* Umbra          *
**************************
Welcome to Umbra - Steganography & Privacy Tool

1. Display metadata (ExifTool)
2. Embed hidden data (Steghide)
3. Extract hidden data (Steghide)
4. Convert an image (ImageMagick)
5. Encrypt a file (OpenSSL)
6. Decrypt a file (OpenSSL)
7. Exit
EOF
}

main() {
    check_and_install_dependencies
    display_menu

    while true; do
        read -r -p "Choose an option (1-7): " option

        case $option in
            1) display_metadata ;;
            2) embed_hidden_data ;;
            3) extract_hidden_data ;;
            4) convert_image ;;
            5) encrypt_file ;;
            6) decrypt_file ;;
            7)
                echo "Goodbye!"
                break
                ;;
            *)
                echo "Invalid option. Please try again." >&2
                ;;
        esac
    done
}

main "$@"

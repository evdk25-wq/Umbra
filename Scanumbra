#!/bin/bash

set -euo pipefail

readonly REQUIRED_COMMANDS=("exiftool" "steghide" "magick" "openssl")

get_package_name() {
    local cmd="$1"
    case "$cmd" in
        "magick") echo "imagemagick" ;;
        *) echo "$cmd" ;;
    esac
}

check_and_install_dependencies() {
    local missing_cmds=()
    local missing_pkgs=()

    for cmd in "${REQUIRED_COMMANDS[@]}"; do
        if ! command -v "$cmd" &> /dev/null; then
            missing_cmds+=("$cmd")
            local pkg
            pkg=$(get_package_name "$cmd")
            missing_pkgs+=("$pkg")
        fi
    done

    if [[ ${#missing_cmds[@]} -gt 0 ]]; then
        echo "Some required tools are missing: ${missing_cmds[*]-}"
        
        if command -v apt &> /dev/null; then
            read -r -p "Do you want to install them via apt now? (y/N) : " response
            if [[ "$response" =~ ^[Yy]$ ]]; then
                echo "Updating repositories and installing packages..."
                sudo apt update && sudo apt install -y "${missing_pkgs[@]}"
            else
                echo "Error: Cannot proceed without the required tools." >&2
                exit 1
            fi
        else
            echo "Please manually install the following packages for your distribution: ${missing_pkgs[*]-}" >&2
            exit 1
        fi

        for cmd in "${REQUIRED_COMMANDS[@]}"; do
            if ! command -v "$cmd" &> /dev/null; then
                echo "Error: Tool $cmd is still missing after verification." >&2
                exit 1
            fi
        done
        echo "All required tools are now operational!"
    fi
}

validate_file_exists() {
    local file="$1"
    if [[ ! -f "$file" ]]; then
        echo "Error: File '$file' does not exist." >&2
        return 1
    fi
    return 0
}

display_metadata() {
    read -r -p "Enter file path: " filepath
    validate_file_exists "$filepath" || return 1
    exiftool "$filepath"
}

embed_hidden_data() {
    read -r -p "Enter cover image: " image
    validate_file_exists "$image" || return 1
    
    read -r -p "Enter file to hide: " data
    validate_file_exists "$data" || return 1
    
    read -r -s -p "Enter secret passphrase: " passphrase
    echo
    
    steghide embed -cf "$image" -ef "$data" -p "$passphrase"
    echo "Embedding completed successfully."
}

extract_hidden_data() {
    read -r -p "Enter cover image: " image
    validate_file_exists "$image" || return 1
    
    read -r -s -p "Enter secret passphrase: " passphrase
    echo
    
    steghide extract -sf "$image" -p "$passphrase"
}

convert_image() {
    read -r -p "Enter JPEG file to convert: " jpeg
    validate_file_exists "$jpeg" || return 1
    
    read -r -p "Enter output PNG file name: " png
    magick "$jpeg" "$png"
    echo "Conversion completed: $png"
}

encrypt_file() {
    read -r -p "Enter file to encrypt: " file
    validate_file_exists "$file" || return 1
    
    read -r -p "Enter output encrypted file name: " output
    openssl enc -aes-256-cbc -salt -pbkdf2 -in "$file" -out "$output"
    echo "File encrypted successfully: $output"
}

decrypt_file() {
    read -r -p "Enter encrypted file: " file
    validate_file_exists "$file" || return 1
    
    read -r -p "Enter output decrypted file name: " output
    openssl enc -aes-256-cbc -d -pbkdf2 -in "$file" -out "$output"
    echo "File decrypted successfully: $output"
}

display_menu() {
    cat << "EOF"

**************************************************
* Scanumbra                                      *
**************************************************
Steganography, Metadata & Privacy CLI Utility

1. Display metadata (ExifTool)
2. Embed hidden data (Steghide)
3. Extract hidden data (Steghide)
4. Convert an image (ImageMagick)
5. Encrypt a file (OpenSSL)
6. Decrypt a file (OpenSSL)
7. Exit
EOF
}

main() {
    check_and_install_dependencies

    while true; do
        display_menu
        read -r -p "Choose an option (1-7): " option

        case "$option" in
            1) display_metadata || true ;;
            2) embed_hidden_data || true ;;
            3) extract_hidden_data || true ;;
            4) convert_image || true ;;
            5) encrypt_file || true ;;
            6) decrypt_file || true ;;
            7)
                echo "Goodbye!"
                break
                ;;
            *)
                echo "Invalid option. Please try again." >&2
                ;;
        esac
    done
}

main "$@"
